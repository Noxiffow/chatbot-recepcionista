      "isMultiMain": false
    }
  },
  "id": "seguimiento-post-servicio",
  "createdAt": "2026-06-19T00:00:00.000Z",
  "updatedAt": "2026-06-19T00:00:00.000Z",
  "description": "Escanea citas que terminaron hace 2h y envía seguimiento post-servicio por WhatsApp. Documentación complementaria — el motor real es Python/APScheduler en app/scheduler.py"
}
