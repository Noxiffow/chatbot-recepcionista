# ═══════════════════════════════════════════════════
# WinoWin Recepcionista — Plantilla de .env
# ═══════════════════════════════════════════════════
# Copia este archivo a .env y rellena los valores:
#   cp .env.example .env
#
# ⚠️ NUNCA subas el archivo .env a Git.
# ⚠️ El token actual es de una cuenta PERSONAL de desarrollo.
#    El cliente DEBE crear su propia cuenta de Meta Business
#    y generar su propio token.

# ── Meta / WhatsApp Cloud API ──────────────────────
# REQUERIDO. Token de acceso permanente de Meta.
# Se obtiene en: Meta for Developers > App > Configuración > Acceso a la API
WHATSAPP_TOKEN=EAA...

# REQUERIDO. ID del número de teléfono de WhatsApp Business.
# Se obtiene en: Meta for Developers > WhatsApp > Configuración > Números de teléfono
PHONE_NUMBER_ID=1103593682842997

# REQUERIDO. ID de la cuenta de WhatsApp Business.
# Se obtiene en: Meta for Developers > WhatsApp > Configuración > Números de teléfono
WABA_ID=975958184791108

# ── Groq AI ────────────────────────────────────────
# REQUERIDO. Clave de API de Groq (gratis).
# Se obtiene en: https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# ── Negocio ────────────────────────────────────────
# Opcional. Nombre del negocio (aparece en el saludo y dashboard).
# Por defecto: "Peluquería WinoWin"
BUSINESS_NAME=Peluquería WinoWin

# Opcional. Tipo de negocio (influye en el prompt del sistema).
# Por defecto: "peluquería"
BUSINESS_TYPE=peluquería

# ── IA Avanzada (opcional) ─────────────────────────
# Modelo de Groq a usar. Opciones:
#   llama-3.3-70b-versatile (recomendado)
#   mixtral-8x7b-32768
#   gemma2-9b-it
# GROQ_MODEL=llama-3.3-70b-versatile

# Máximo de tokens de respuesta (default: 512)
# GROQ_MAX_TOKENS=512

# Creatividad del modelo (0.0 = preciso, 1.0 = creativo)
# GROQ_TEMPERATURE=0.7

# ── Servidor (opcional, valores por defecto) ──────
# HOST=0.0.0.0
# PORT=8000
